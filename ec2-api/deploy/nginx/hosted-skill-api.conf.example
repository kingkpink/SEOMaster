# HTTPS via Tailscale certs — proxy to uvicorn on localhost:8000.
# Certs live at /etc/tailscale-certs/ (created by deploy/setup-https.sh).

# Redirect HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name awsec2.tail0fdcca.ts.net;
    return 301 https://$host$request_uri;
}

# HTTPS
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name awsec2.tail0fdcca.ts.net;

    ssl_certificate     /etc/tailscale-certs/awsec2.tail0fdcca.ts.net.crt;
    ssl_certificate_key /etc/tailscale-certs/awsec2.tail0fdcca.ts.net.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # Security headers
    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Restrict OpenAPI docs in production (uncomment to block)
    # location /docs { return 404; }
    # location /openapi.json { return 404; }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}
